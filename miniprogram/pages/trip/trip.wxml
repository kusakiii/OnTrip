<!--
  行程详情页
  结构：Header → DayTabs → Card列表（时间轴）→ FloatingChat
-->
<view class="trip-root">
  <!-- ═══ Header：目的地 + 天数 + 视图切换 ═══ -->
  <view class="trip-header" wx:if="{{trip}}">
    <view class="header-info">
      <text class="text-h2">{{trip.destination.city}}</text>
      <text class="text-caption text-tertiary"
        >{{trip.days}}天 · {{trip.styleTags.length > 0 ? '' : '综合'}}行程</text
      >
    </view>
    <view class="header-actions">
      <view class="header-action" bindtap="onViewModeToggle">
        <text>{{viewMode === 'timeline' ? '🗺' : '📋'}}</text>
      </view>
      <view class="header-action" bindtap="onExport">
        <text>📤</text>
      </view>
    </view>
  </view>

  <!-- ═══ Day 标签切换 ═══ -->
  <scroll-view
    class="day-tabs"
    scroll-x
    enhanced
    show-scrollbar="{{false}}"
    wx:if="{{trip && viewMode === 'timeline'}}"
  >
    <view class="day-tabs-inner">
      <t-tag
        wx:for="{{dayTabs}}"
        wx:key="index"
        label="{{item.label}} ({{item.summary.spotCount}})"
        selected="{{activeDayIndex === index}}"
        data-index="{{index}}"
        bindtap="onDayTabTap"
      ></t-tag>
    </view>
  </scroll-view>

  <!-- ═══ 时间轴卡片列表 ═══ -->
  <scroll-view
    class="card-list"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    wx:if="{{trip && viewMode === 'timeline'}}"
  >
    <view class="card-list-inner">
      <block wx:for="{{trip.itinerary[activeDayIndex].cards}}" wx:key="cardId">
        <trip-card
          card="{{item}}"
          isFirst="{{index === 0}}"
          isLast="{{index === trip.itinerary[activeDayIndex].cards.length - 1}}"
          dayIndex="{{activeDayIndex}}"
          index="{{index}}"
          dayColor="{{'#2E7D32'}}"
          bind:tap="onCardTap"
          bind:star="onStarTap"
          bind:replace="onReplaceTap"
          bind:delete="onDeleteTap"
        ></trip-card>
      </block>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{trip.itinerary[activeDayIndex].cards.length === 0}}">
      <text class="text-body text-tertiary">该天暂无行程安排</text>
    </view>
  </scroll-view>

  <!-- ═══ 地图视图（占位） ═══ -->
  <view class="map-placeholder" wx:if="{{trip && viewMode === 'map'}}">
    <text class="text-body text-tertiary">地图视图开发中</text>
    <text class="text-caption text-tertiary"
      >将显示 {{trip.itinerary[activeDayIndex].cards.length}} 个地点</text
    >
  </view>

  <!-- ═══ 浮动聊天按钮 ═══ -->
  <view class="floating-chat" bindtap="onChatToggle" wx:if="{{trip && !chatSheetShow}}">
    <text class="chat-icon">💬</text>
    <text class="text-caption">调整行程</text>
  </view>

  <!-- ═══ 卡片详情 BottomSheet ═══ -->
  <t-bottom-sheet
    show="{{detailSheetShow}}"
    title="{{detailSheetCard.name}}"
    bindclose="onDetailSheetClose"
  >
    <card-detail-sheet
      card="{{detailSheetCard}}"
      bindstar="onStarTap"
      bindreplace="onReplaceTap"
      binddelete="onDeleteTap"
    ></card-detail-sheet>
  </t-bottom-sheet>

  <!-- ═══ 聊天面板 BottomSheet ═══ -->
  <t-bottom-sheet
    show="{{chatSheetShow}}"
    title="调整行程"
    maxHeightRatio="{{0.55}}"
    bindclose="onChatSheetClose"
  >
    <chat-panel tripId="{{trip.tripId}}"></chat-panel>
  </t-bottom-sheet>

  <!-- Toast -->
  <t-toast
    message="{{toastMessage}}"
    type="{{toastType}}"
    show="{{toastShow}}"
    bindhide="onToastHide"
  ></t-toast>
</view>
