/**
 * 行程详情页样式
 *
 * 布局：Header → DayTabs → CardList → FloatingChat
 * 原则：卡片是主角，其他元素围绕卡片
 */

.trip-root {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-surface);
}

/* ── Header ── */
.trip-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg) var(--space-lg) var(--space-md);
  background: var(--color-bg);
}
.header-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}
.header-actions {
  display: flex;
  gap: var(--space-lg);
}
.header-action {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-btn);
  background: var(--color-surface);
  font-size: var(--font-title);
}
.header-action:active {
  opacity: 0.6;
}

/* ── Day 标签切换 ── */
.day-tabs {
  padding: var(--space-sm) var(--space-lg);
  background: var(--color-bg);
  border-bottom: 1rpx solid var(--color-border-light);
}
.day-tabs-inner {
  display: inline-flex;
  gap: var(--space-sm);
  white-space: nowrap;
}

/* ── 卡片列表 ── */
.card-list {
  flex: 1;
  padding-top: var(--space-lg);
}
.card-list-inner {
  padding-bottom: 120rpx; /* 为浮动按钮留空间 */
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-3xl);
  gap: var(--space-sm);
}

/* ── 地图占位 ── */
.map-placeholder {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-md);
  background: var(--color-surface);
}

/* ── 浮动聊天按钮 ── */
.floating-chat {
  position: fixed;
  bottom: var(--space-2xl);
  right: var(--space-2xl);
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-md) var(--space-lg);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-avatar);
  box-shadow: var(--shadow-dialog);
  z-index: 100;
  transition: transform var(--duration-fast) var(--easing-default);
}
.floating-chat:active {
  transform: scale(0.95);
}
.chat-icon {
  font-size: var(--font-title);
}
