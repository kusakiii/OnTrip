/**
 * 行程详情页 — US-05 卡片列表
 *
 * 布局：Header → 垂直堆叠 Days → FloatingChat
 * 每个 Day：可折叠标题栏 + 卡片时间轴列表
 */

.trip-root {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-surface);
}

/* ── Header ── */
.trip-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg) var(--space-lg) var(--space-md);
  background: var(--color-bg);
}
.header-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}
.header-actions {
  display: flex;
  gap: var(--space-lg);
}
.header-action {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-btn);
  background: var(--color-surface);
  font-size: var(--font-title);
}
.header-action:active {
  opacity: 0.6;
}

/* ── Day 列表 ═══ */
.day-list {
  flex: 1;
}
.day-list-inner {
  padding-bottom: 40rpx;
}

/* ── Day 标题栏（可折叠） ═══ */
.day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg);
  margin: var(--space-sm) var(--space-lg);
  background: var(--color-bg);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}
.day-header:active {
  opacity: 0.7;
}
.day-header-left {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}
.day-title {
  color: var(--color-text);
}
.day-summary {
  display: flex;
  gap: var(--space-lg);
}
.day-arrow {
  font-size: var(--font-caption);
  color: var(--color-text-tertiary);
  transition: transform var(--duration-normal) var(--easing-default);
}
.arrow-expanded {
  transform: rotate(180deg);
}

/* ── 卡片列表 ── */
.day-cards {
  padding: var(--space-sm) 0;
}

/* ── 空天 ── */
.empty-day {
  padding: var(--space-xl);
  text-align: center;
}

/* ── 底部留白 ── */
.list-bottom-spacer {
  height: 120rpx;
}

/* ── 加载态 ── */
.loading-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── 空状态 ── */
.empty-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── 浮动聊天按钮 ── */
.floating-chat {
  position: fixed;
  bottom: var(--space-2xl);
  right: var(--space-2xl);
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-md) var(--space-lg);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-avatar);
  box-shadow: var(--shadow-dialog);
  z-index: 100;
}
.floating-chat:active {
  transform: scale(0.95);
}
.chat-icon {
  font-size: var(--font-title);
}
