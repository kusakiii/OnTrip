{
  "name": "tripflow",
  "version": "1.0.0",
  "description": "途灵 TripFlow — AI 行程规划微信小程序",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint miniprogram/ cloud/ tests/",
    "lint:fix": "eslint miniprogram/ cloud/ tests/ --fix",
    "check": "npm run format:check && npm run lint && npm run test:unit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:prompts": "node tests/prompt/run-tests.js",
    "test:unit": "jest tests/unit/"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,wxml,wxss,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "eslint": "^8.50.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4"
  },
  "dependencies": {
    "mobx-miniprogram": "^6.0.0",
    "mobx-miniprogram-bindings": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "moduleNameMapper": {
      "^@domain/(.*)$": "<rootDir>/miniprogram/domain/$1",
      "^@use-cases/(.*)$": "<rootDir>/miniprogram/use-cases/$1",
      "^@utils/(.*)$": "<rootDir>/miniprogram/utils/$1"
    }
  }
}
